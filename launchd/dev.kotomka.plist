    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/yoda/dev/pet/kotomka/data/launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/yoda/dev/pet/kotomka/data/launchd.err.log</string>
