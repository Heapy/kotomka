# Local service
KOTOMKA_HOST=127.0.0.1
KOTOMKA_PORT=8000
KOTOMKA_DATA_DIR=data

# Providers: auto chooses codex_subscription if logged in, then openai if
# OPENAI_API_KEY exists, otherwise fake.
KOTOMKA_LLM_PROVIDER=auto
KOTOMKA_STT_PROVIDER=fake
# Default avoids launching system browsers from Codex. Set to browser only if
# you intentionally want Chrome/Playwright PDF rendering in your own shell.
KOTOMKA_PDF_RENDERER=reportlab

# Optional live providers.
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=

# Optional Codex subscription route. Run:
#   uv run kotomka codex-login
CODEX_SUBSCRIPTION_AUTH_FILE=data/codex_subscription_auth.json
